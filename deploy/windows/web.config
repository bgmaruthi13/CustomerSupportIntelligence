<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse-proxy config for Correlate AI, via Application Request Routing (ARR)
  + URL Rewrite. Place this in the IIS site's physical root (see README.md — do
  NOT point the IIS site root at the Django app folder itself; use a separate,
  empty "site root" folder containing only this file, plus a /static virtual
  directory pointing at staticfiles\, configured in IIS Manager).

  Prerequisites (see README.md for install links):
    - IIS "Web Server (IIS)" role
    - "Application Request Routing" (ARR) module
    - "URL Rewrite" module
    - ARR's proxy feature enabled (IIS Manager > Server node > Application
      Request Routing Cache > Server Proxy Settings > "Enable proxy")
    - The two custom server variables below (HTTP_X_FORWARDED_PROTO,
      HTTP_X_FORWARDED_HOST) allow-listed under IIS Manager > URL Rewrite >
      View Server Variables (or via appcmd — see README.md) — IIS blocks
      setting arbitrary server variables from a rewrite rule until you do this.
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- /static/* is served directly by IIS (see the virtual directory setup
             in README.md) and never reaches this rule. Everything else is
             reverse-proxied to the waitress process on localhost. -->
        <rule name="CorrelateAI-ReverseProxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_URI}" pattern="^/static/" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
          <serverVariables>
            <!-- Django's SECURE_PROXY_SSL_HEADER (settings.py) reads this to know
                 the original request was HTTPS, since the connection from IIS to
                 waitress on localhost is always plain HTTP. -->
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Belt-and-suspenders: DATA_UPLOAD_MAX_MEMORY_SIZE in settings.py caps
         Django's own accepted upload size at 25MB, but IIS's default request
         limit is lower — this raises IIS's ceiling to match so a legitimate
         25MB ticket export isn't rejected by IIS before Django even sees it. -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="26214400" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
