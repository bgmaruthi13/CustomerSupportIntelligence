# Copy this file to .env and fill in real values before running in production.
# Nothing in this file is read unless a .env exists next to manage.py.

# --- Core ---------------------------------------------------------------
# Generate one with:
#   venv\Scripts\python.exe -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# False in production. True is fine for local dev (shows tracebacks in-browser).
DJANGO_DEBUG=False

# Comma-separated hostnames/IPs this server will be reached at.
DJANGO_ALLOWED_HOSTS=correlate.yourcompany.local,10.0.0.5

# Only needed if serving over HTTPS from a non-standard origin (reverse proxy, custom port).
DJANGO_CSRF_TRUSTED_ORIGINS=https://correlate.yourcompany.local

# Set to False only if this instance is intentionally plain-HTTP on a trusted internal
# network with no reverse-proxy TLS termination. Leave True whenever HTTPS is in front.
DJANGO_BEHIND_TLS=True

# --- Database -------------------------------------------------------------
# Omit entirely to use the zero-config SQLite file (db.sqlite3) — fine for a single
# Windows machine / pilot deployment. Set this to point at Postgres instead:
#   DATABASE_URL=postgres://correlate_user:password@localhost:5432/correlate
# (requires: pip install -r requirements-postgres.txt)
# DATABASE_URL=

# --- Email (logscan alert digests) -----------------------------------------
# Only needed if any Log Source has alert_emails configured. Without these set,
# email sending is skipped with a warning logged — a scan job still completes
# and its findings are always visible in-app (Log PII Alerts) regardless.
# Leave DJANGO_EMAIL_HOST blank to use Django's console backend (prints emails
# to the server log instead of sending — useful for testing the digest content
# without real SMTP configured).
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_ALERT_FROM_EMAIL=correlate-alerts@yourcompany.local

# --- Log scanning ------------------------------------------------------------
# Max size (MB) for a browser-uploaded log file (logscan Log Sources, source
# type "Uploaded file"). Filesystem/network path sources aren't affected by
# this at all — it only governs the HTTP upload path. Default 2048 (2GB); a
# true 100GB file should use a path source instead of browser upload regardless
# (see the Log Sources page's own note on this).
LOGSCAN_UPLOAD_MAX_MB=2048
